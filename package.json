{
  "name": "@avleon/core",
  "version": "0.1.03",
  "description": "TypeScript-first web framework built on Fastify",
  "author": "Tareq Hossain",
  "license": "ISC",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "restapi",
    "avleon",
    "backend",
    "fastify",
    "typescript"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "husky:init": "husky install"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/view": "^11.0.0",
    "@scalar/fastify-api-reference": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.1.0",
    "fastify-socket.io": "^4.0.0",
    "ioredis": "^5.10.1",
    "knex": "^3.1.0",
    "mime": "^3.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.0.0",
    "typedi": "^0.10.0",
    "typeorm": "^0.3.28"
  },
  "optionalDependencies": {
    "mssql": "^11.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.17",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.4",
    "tsdown": "^0.12.0",
    "typescript": "^5.7.2",
    "unplugin-unused": "^0.5.7"
  },
  "lint-staged": {
    "*.{js,ts,json,md}": "pnpm format",
    "*.{js,ts}": [
      "pnpm lint:fix",
      "cross-env CI=true jest --bail --findRelatedTests --passWithNoTests --config=jest.config.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avleonjs/avleon-core"
  },
  "publishConfig": {
    "access": "public"
  }
}
