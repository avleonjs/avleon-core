{
  "compilerOptions": {
    // Environment
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],

    // Decorators (typeorm, typedi, class-validator)
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    // Type checking
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,

    // tsdown owns emit — tsc is type-check only
    "noEmit": true,
    "declaration": false,
    "outDir": "./dist",

    // Node 20 built-ins
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}

